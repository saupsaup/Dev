{
  "version": "2.0.0",
  "tasks": [

    {
      "label": "VM: Start",
      "type": "shell",
      "command": "prlctl",
      "args": ["start", "Windows 11"],
      "problemMatcher": []
    },
    {
      "label": "VM: Resume",
      "type": "shell",
      "command": "prlctl",
      "args": ["resume", "Windows 11"],
      "problemMatcher": []
    },
    {
      "label": "VM: Suspend",
      "type": "shell",
      "command": "prlctl",
      "args": ["suspend", "Windows 11"],
      "problemMatcher": []
    },
    {
      "label": "VM: Stop",
      "type": "shell",
      "command": "prlctl",
      "args": ["stop", "Windows 11"],
      "problemMatcher": []
    },


    {
      "label": "Mosaic build (VM, M:)",
      "type": "shell",
      "command": "prlctl",
      "args": [
        "exec", "Windows 11", "cmd", "/c",
        "net use M: /delete /y >NUL 2>&1 & net use M: \"\\\\Mac\\Mosaic\" /persistent:no & \"C:\\\\Program Files (x86)\\\\Teco\\\\Mosaic 2025.1\\\\Application\\\\MosaicL.exe\" -ttr -lnk -sg+ -sr- -log- -pub -olc- -psw- -plcpsw- -sc- -sl- -exml- -epub- -eexp+ M:\\\\NachHouseApp\\\\Dev\\\\Dev_V200\\\\200\\\\200.mak"
      ],
      "problemMatcher": {
        "owner": "st",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^\\[ST:(Warning|Error)\\]\\s+([^\\s]+)\\s+\\((\\d+),\\s*(\\d+)\\):\\s+(.*)$",
          "severity": 1,
          "file": 2,
          "line": 3,
          "column": 4,
          "message": 5
        }
      },
      "group": { "kind": "build", "isDefault": true }
    },


    {
